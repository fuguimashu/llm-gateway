# ── LLM Gateway Environment Variables ────────────────────────────────────────
# Copy to .env and fill in values before running docker compose

# Master key for admin operations (create/delete virtual keys, view logs)
# Generate with: openssl rand -hex 32
MASTER_KEY=changeme-replace-with-strong-key

# SQLite database path (inside container; mapped via volume)
DATABASE_URL=sqlite:///./data/llm_gateway.db

# Path to your config.yaml (mapped into the backend container)
# CONFIG_PATH=/app/config.yaml   # default, usually no need to change

# Frontend: backend API URL as seen from the BROWSER (not from within Docker)
# If running locally: http://localhost:8000
# If behind a reverse proxy: https://your-domain.com/api
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional: tighten CORS (comma-separated origins, default is *)
# CORS_ORIGINS=http://localhost:3000,https://your-domain.com
